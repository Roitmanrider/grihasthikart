APP_NAME=GrihasthiKart
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_hostinger_database
DB_USERNAME=your_hostinger_database_user
DB_PASSWORD=your_strong_database_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=mailbox@your-domain.example
MAIL_PASSWORD=your_mailbox_password
MAIL_FROM_ADDRESS=mailbox@your-domain.example
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Comma-separated production admin emails. Leave blank to grant no implicit admin access.
GRIHASTHIKART_ADMIN_EMAILS=owner@your-domain.example

# Payment settings are managed from Admin > Settings > Payments.
# Do not commit live Razorpay secrets or payment QR assets.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYMENT_QR_UPI_ID=
PAYMENT_QR_DISPLAY_NAME=
